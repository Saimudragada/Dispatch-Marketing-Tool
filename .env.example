# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase — Settings > Database > Connection string
DATABASE_URL=            # Transaction pooler connection (port 6543), used at runtime
DIRECT_URL=               # Direct connection (port 5432), used only for Prisma migrations

# Supabase — Settings > API
NEXT_PUBLIC_SUPABASE_URL=              # Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Publishable key (sb_publishable_...)
SUPABASE_SERVICE_ROLE_KEY=             # Secret key (sb_secret_...) — server-only, never expose to client

# Anthropic
ANTHROPIC_API_KEY=                     # Server-only, used in API routes only